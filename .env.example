# configuração do supabase — pegar no painel do projeto em Settings > API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica-aqui

# chave da API Gemini — usada no módulo Canon pra geração de minutas
VITE_GEMINI_API_KEY=sua-chave-gemini-aqui

# config geral da aplicação
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=JusLaboral
VITE_APP_VERSION=1.0.0
